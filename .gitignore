!tables/.gitkeep
!outputs/.gitkeep
outputs/**/cache/
outputs/**/quarantine*/
outputs/**/*.npz
outputs/**/*.pt
outputs/**/*.pth
outputs/**/*.log
outputs/**/*.executed.ipynb
