# Python/runtime artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.ipynb_checkpoints/

# Local environments and editor state
.env
.venv/
venv/
env/
.DS_Store

# Large local datasets. Keep dataset cards and small tabular examples tracked.
data/**/*.h5ad
data/**/*.npz
data/**/*.zip
